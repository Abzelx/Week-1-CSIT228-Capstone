<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 24;">

    <Label text="Report New Incident"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Separator/>

    <GridPane hgap="16.0" vgap="14.0">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" prefWidth="140.0"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
        </columnConstraints>

        <!-- Incident Type -->
        <Label text="Incident Type *" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-size: 13px;"/>
        <ComboBox promptText="Select disaster type" maxWidth="Infinity"
                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <!-- Location -->
        <Label text="Location *" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-size: 13px;"/>
        <TextField promptText="e.g. Barangay San Jose, Antique" maxWidth="Infinity"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <!-- Date -->
        <Label text="Date Occurred *" GridPane.rowIndex="2" GridPane.columnIndex="0"
               style="-fx-font-size: 13px;"/>
        <DatePicker maxWidth="Infinity"
                    GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- Severity -->
        <Label text="Severity" GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-size: 13px;"/>
        <ComboBox promptText="Select severity level" maxWidth="Infinity"
                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <!-- Description -->
        <Label text="Description" GridPane.rowIndex="4" GridPane.columnIndex="0"
               style="-fx-font-size: 13px;" GridPane.valignment="TOP"/>
        <TextArea promptText="Describe what happened, affected areas, and current situation..."
                  prefRowCount="4" wrapText="true" maxWidth="Infinity"
                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    </GridPane>

    <!-- Validation message -->
    <Label text="" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;"/>

    <!-- Action buttons -->
    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button text="Clear" style="-fx-pref-width: 90; -fx-pref-height: 36;"/>
        <Button text="Submit Report" defaultButton="true"
                style="-fx-pref-width: 140; -fx-pref-height: 36;"/>
    </HBox>

    <!-- Progress indicator -->
    <Label text="Saving report..." style="-fx-text-fill: #2563eb; -fx-font-size: 12px;"/>

</VBox>