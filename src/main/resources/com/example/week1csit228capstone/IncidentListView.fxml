<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 24;">

    <Label text="Incident List"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Separator/>

    <!-- Filter / Search row -->
    <HBox spacing="12.0" alignment="CENTER_LEFT">
        <TextField promptText="Search by keyword or location..."
                   prefWidth="280.0"/>
        <ComboBox promptText="Filter by type"
                  prefWidth="160.0"/>
        <ComboBox promptText="Filter by status"
                  prefWidth="160.0"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Clear Filters"/>
        <Button text="Refresh"/>
    </HBox>

    <!-- Incident TableView -->
    <TableView VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No incidents found." />
        </placeholder>
        <columns>
            <TableColumn text="ID" prefWidth="55"/>
            <TableColumn text="Type" prefWidth="110"/>
            <TableColumn text="Location" prefWidth="200"/>
            <TableColumn text="Date" prefWidth="105"/>
            <TableColumn text="Status" prefWidth="100"/>
            <TableColumn text="Reported By" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Bottom row: record count + action buttons -->
    <HBox spacing="12.0" alignment="CENTER_LEFT">
        <Label text="0 incidents"
               style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="View Details" disable="true"/>
        <Button text="Update Status" disable="true"/>
    </HBox>

</VBox>