<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      prefWidth="380.0" minHeight="320.0"
      style="-fx-padding: 40;">

    <Label text="Disaster Report System"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <Label text="Community Incident Monitoring"
           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>

    <VBox spacing="8.0" maxWidth="320.0" VBox.vgrow="NEVER">
        <Label text="Username"/>
        <TextField promptText="Enter your username" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="8.0" maxWidth="320.0" VBox.vgrow="NEVER">
        <Label text="Password"/>
        <PasswordField promptText="Enter your password" maxWidth="Infinity"/>
    </VBox>

    <Label text="" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;"/>

    <Button text="Log In"
            maxWidth="320.0"
            defaultButton="true"
            style="-fx-pref-height: 36px;"/>

    <HBox alignment="CENTER" spacing="4.0">
        <Label text="No account?" style="-fx-font-size: 13px;"/>
        <Hyperlink text="Register here" style="-fx-font-size: 13px;"/>
    </HBox>

</VBox>